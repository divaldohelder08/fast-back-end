.error({
  UNAUTHORIZED: UnauthorizedError,
  NOT_A_MANAGER: NotAManagerError,
})
.onError(({ code, error, set }) => {
    switch (code) {
      case "UNAUTHORIZED":
        set.status = 401;
        return { code, message: error.message };
      case "NOT_A_MANAGER":
        set.status = 401;
        return { code, message: error.message };
    }
  })