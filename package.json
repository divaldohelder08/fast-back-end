{
  "name": "fast-back-end",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch --trace-warnings src/http/server.ts",
    "build": "tsup src",
    "start": "node dist/server.js",
    "mon": "ts-node-dev --respawn --transpile-only src/http/server.ts",
    "prisma": "npx prisma"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@mermaid-js/mermaid-cli": "^10.8.0",
    "@rocketseat/eslint-config": "^2.2.2",
    "@types/bcrypt": "^5.0.2",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.28",
    "chalk": "^5.3.0",
    "eslint": "^8.57.0",
    "prisma": "^5.11.0",
    "prisma-erd-generator": "^1.11.2",
    "tsnd": "^1.1.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "dayjs": "^1.11.10",
    "fastify": "^4.26.2",
